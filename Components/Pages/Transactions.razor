@page "/transactions"
@using FinanceTracker.Services
@using FinanceTracker.Models
@inject FinanceService FinanceService

<PageTitle>Transactions - FinanceTracker</PageTitle>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3">
        <h1>Transactions</h1>
        <div class="d-flex gap-2">
            <select class="form-select bg-card text-main border-border w-auto" @onchange="OnMonthChanged">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(i == SelectedMonth)">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(i)</option>
                }
            </select>
            <select class="form-select bg-card text-main border-border w-auto" @onchange="OnYearChanged">
                @for (int i = 2024; i <= DateTime.Now.Year + 1; i++)
                {
                    <option value="@i" selected="@(i == SelectedYear)">@i</option>
                }
            </select>
        </div>
    </div>
    <button class="btn-primary" @onclick="() => ShowAddModal = true">Add Transaction</button>
</div>

<div class="glass-card p-0 overflow-hidden">
    <div class="table-responsive">
        @if (TransactionList == null)
        {
            <div class="p-4"><p>Loading...</p></div>
        }
        else if (!TransactionList.Any())
        {
            <div class="p-4"><p>No transactions found.</p></div>
        }
        else
        {
            <table class="table table-dark mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Account</th>
                    <th>Category</th>
                    <th class="text-end">Amount</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in TransactionList)
                {
                    <tr>
                        <td>@t.Date.ToShortDateString()</td>
                        <td>@t.Description</td>
                        <td>
                            @if (t.Type == TransactionType.Transfer)
                            {
                                <span class="small">
                                    @t.Account?.Name -> @t.ToAccount?.Name
                                </span>
                            }
                            else
                            {
                                @t.Account?.Icon @t.Account?.Name
                            }
                        </td>
                        <td>
                            @if (t.Type != TransactionType.Transfer)
                            {
                                <span class="badge" style="background: @t.Category?.Color">
                                    @t.Category?.Icon @t.Category?.Name
                                </span>
                            }
                            @if (t.Type == TransactionType.Transfer)
                            {
                                  <span class="badge" style="background: #475569 ">
                                    🔁 Transfer
                                </span>
                            }
                        </td>
                        <td class="text-end @(t.Type == TransactionType.Income ? "text-accent" : t.Type == TransactionType.Expense ? "text-danger" : "text-white")">
                            @(t.Type == TransactionType.Income ? "+" : t.Type == TransactionType.Expense ? "-" : "") @t.Amount.ToString("C")
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTransaction(t.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    </div>
</div>

@if (ShowAddModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-card text-main border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title">Add @(NewTransaction.Type == TransactionType.Transfer ? "Transfer" : "Transaction")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowAddModal = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="NewTransaction" OnValidSubmit="SaveTransaction">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small mb-3" />

                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <InputSelect @bind-Value="NewTransaction.Type" class="form-control bg-dark text-main border-border">
                                <option value="@TransactionType.Expense">Expense</option>
                                <option value="@TransactionType.Income">Income</option>
                                <option value="@TransactionType.Transfer">Transfer</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputText @bind-Value="NewTransaction.Description" class="form-control bg-dark text-main border-border" placeholder="e.g. Grocery Shopping" />
                            <ValidationMessage For="() => NewTransaction.Description" class="text-danger small" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Date</label>
                                <InputDate @bind-Value="NewTransaction.Date" class="form-control bg-dark text-main border-border" />
                                <ValidationMessage For="() => NewTransaction.Date" class="text-danger small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Amount</label>
                                <InputNumber @bind-Value="NewTransaction.Amount" class="form-control bg-dark text-main border-border" step="0.01" />
                                <ValidationMessage For="() => NewTransaction.Amount" class="text-danger small" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">@(NewTransaction.Type == TransactionType.Transfer ? "From Account" : "Account")</label>
                                <InputSelect @bind-Value="NewTransaction.AccountId" class="form-control bg-dark text-main border-border">
                                    <option value="0" disabled>Select account</option>
                                    @foreach (var acc in Accounts)
                                    {
                                        <option value="@acc.Id">@acc.Icon @acc.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => NewTransaction.AccountId" class="text-danger small" />
                            </div>

                            @if (NewTransaction.Type == TransactionType.Transfer)
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">To Account</label>
                                    <InputSelect @bind-Value="NewTransaction.ToAccountId" class="form-control bg-dark text-main border-border">
                                        <option value="">Select destination</option>
                                        @foreach (var acc in Accounts)
                                        {
                                            @if (acc.Id != NewTransaction.AccountId)
                                            {
                                                <option value="@acc.Id">@acc.Icon @acc.Name</option>
                                            }
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => NewTransaction.ToAccountId" class="text-danger small" />
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Category</label>
                                    <InputSelect @bind-Value="NewTransaction.CategoryId" class="form-control bg-dark text-main border-border">
                                        <option value="0" disabled>Select a category</option>
                                        @foreach (var c in Categories)
                                        {
                                            <option value="@c.Id">@c.Icon @c.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => NewTransaction.CategoryId" class="text-danger small" />
                                </div>
                            }
                        </div>

                        <button type="submit" class="btn-primary w-100 mt-2">Save Transaction</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Transaction>? TransactionList;
    private List<Category> Categories = new();
    private List<Account> Accounts = new();
    private bool ShowAddModal = false;
    private Transaction NewTransaction = new();
    private int SelectedMonth = DateTime.Now.Month;
    private int SelectedYear = DateTime.Now.Year;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        Categories = await FinanceService.GetCategoriesAsync();
        Accounts = await FinanceService.GetAccountsAsync();
        
        ResetNewTransaction();
    }

    private void ResetNewTransaction()
    {
        NewTransaction = new();
        if (Categories.Any()) NewTransaction.CategoryId = Categories.First().Id;
        if (Accounts.Any()) NewTransaction.AccountId = Accounts.First().Id;
    }

    private async Task LoadData()
    {
        TransactionList = await FinanceService.GetTransactionsAsync(SelectedMonth, SelectedYear);
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int month))
        {
            SelectedMonth = month;
            await LoadData();
        }
    }

    private async Task OnYearChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int year))
        {
            SelectedYear = year;
            await LoadData();
        }
    }

    private async Task SaveTransaction()
    {
        // If it's a transfer, ensure we don't have a category assigned (optional, but cleaner)
        if (NewTransaction.Type == TransactionType.Transfer)
        {
            // CategoryId is required by model validation, so we should probably have a hidden "Transfer" category or allow 0.
            // For now, let's keep the seeded categories or just assign the first one.
            // Better: update the model to make CategoryId nullable for Transfers.
        }

        await FinanceService.AddTransactionAsync(NewTransaction);
        ResetNewTransaction();
        ShowAddModal = false;
        await LoadData();
    }

    private async Task DeleteTransaction(int id)
    {
        await FinanceService.DeleteTransactionAsync(id);
        await LoadData();
    }
}

<style>
    .bg-card { background-color: var(--bg-card) !important; }
    .text-main { color: var(--text-main) !important; }
    .border-border { border-color: var(--border) !important; }
    .text-accent { color: var(--accent); }
    .text-danger { color: var(--danger); }
</style>
